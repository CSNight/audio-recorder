{
  "name": "@csnight/audio-recorder",
  "private": false,
  "version": "1.0.9",
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "description": "TypeScript browser audio recorder for microphone and MediaStream input with PCM pipelines, plugins, streaming export, persistence, and WAV/MP3/Opus/FLAC/AAC/AMR/AC3 output.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "README.zh-CN.md",
    "LICENSE",
    "THIRD_PARTY_NOTICES.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CSNight/audio-recorder.git"
  },
  "homepage": "https://github.com/CSNight/audio-recorder#readme",
  "bugs": {
    "url": "https://github.com/CSNight/audio-recorder/issues"
  },
  "keywords": [
    "audio-recorder",
    "browser-audio-recorder",
    "voice-recording",
    "microphone-recorder",
    "mediarecorder",
    "webaudio",
    "mediastream",
    "pcm",
    "wav",
    "mp3",
    "opus",
    "flac",
    "aac",
    "amr",
    "ac3",
    "typescript",
    "wasm"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "prepare": "husky",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build:wasm": "node ./scripts/wasm/build-docker.mjs --codec=all",
    "build:wasm:select": "node ./scripts/wasm/build-docker.mjs",
    "benchmark:codecs": "node ./scripts/benchmark-codecs.mjs",
    "test": "npm run test:unit && npm run test:functional",
    "test:unit": "vitest run --coverage",
    "test:functional": "playwright test",
    "test:functional:headed": "playwright test --headed",
    "lint": "eslint . --fix",
    "format": "prettier --write .",
    "commitlint": "commitlint --edit",
    "check": "npm run lint && npm run typecheck && npm run test && npm run build && npm run verify:exports",
    "verify:exports": "node ./scripts/verify-exports.mjs",
    "publish": "npm run build && npm publish --access public --registry=https://registry.npmjs.org/"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./plugins/level-meter": {
      "types": "./dist/plugins/level-meter/index.d.ts",
      "import": "./dist/plugins/level-meter/index.js"
    },
    "./storage/opfs": {
      "types": "./dist/storage/opfs/index.d.ts",
      "import": "./dist/storage/opfs/index.js"
    },
    "./storage/indexeddb": {
      "types": "./dist/storage/indexeddb/index.d.ts",
      "import": "./dist/storage/indexeddb/index.js"
    },
    "./plugins/streaming-export": {
      "types": "./dist/plugins/streaming-export/index.d.ts",
      "import": "./dist/plugins/streaming-export/index.js"
    },
    "./plugins/streaming-player": {
      "types": "./dist/plugins/streaming-player/index.d.ts",
      "import": "./dist/plugins/streaming-player/index.js"
    },
    "./plugins/sonic-export": {
      "types": "./dist/plugins/sonic-export/index.d.ts",
      "import": "./dist/plugins/sonic-export/index.js"
    },
    "./plugins/dsp": {
      "types": "./dist/plugins/dsp/index.d.ts",
      "import": "./dist/plugins/dsp/index.js"
    },
    "./plugins/asr-export": {
      "types": "./dist/plugins/asr-export/index.d.ts",
      "import": "./dist/plugins/asr-export/index.js"
    },
    "./plugins/frequency-histogram": {
      "types": "./dist/plugins/frequency-histogram/index.d.ts",
      "import": "./dist/plugins/frequency-histogram/index.js"
    },
    "./plugins/dtmf": {
      "types": "./dist/plugins/dtmf/index.d.ts",
      "import": "./dist/plugins/dtmf/index.js"
    },
    "./plugins/nmn2pcm": {
      "types": "./dist/plugins/nmn2pcm/index.d.ts",
      "import": "./dist/plugins/nmn2pcm/index.js"
    },
    "./codecs/mp3": {
      "types": "./dist/codecs/mp3/index.d.ts",
      "import": "./dist/codecs/mp3/index.js"
    },
    "./codecs/base": {
      "types": "./dist/codecs/base/index.d.ts",
      "import": "./dist/codecs/base/index.js"
    },
    "./codecs/g711": {
      "types": "./dist/codecs/g711/index.d.ts",
      "import": "./dist/codecs/g711/index.js"
    },
    "./codecs/opus": {
      "types": "./dist/codecs/opus/index.d.ts",
      "import": "./dist/codecs/opus/index.js"
    },
    "./codecs/flac": {
      "types": "./dist/codecs/flac/index.d.ts",
      "import": "./dist/codecs/flac/index.js"
    },
    "./codecs/aac": {
      "types": "./dist/codecs/aac/index.d.ts",
      "import": "./dist/codecs/aac/index.js"
    },
    "./codecs/amr": {
      "types": "./dist/codecs/amr/index.d.ts",
      "import": "./dist/codecs/amr/index.js"
    },
    "./codecs/ac3": {
      "types": "./dist/codecs/ac3/index.d.ts",
      "import": "./dist/codecs/ac3/index.js"
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.0.12",
    "vitest": "^4.1.8"
  },
  "prettier": {
    "singleQuote": false,
    "semi": false,
    "trailingComma": "es5",
    "bracketSpacing": true,
    "endOfLine": "lf",
    "bracketSameLine": false,
    "cursorOffset": 2
  },
  "lint-staged": {
    "src/**/*.{ts,tsx,json,css,scss,md}": [
      "npm lint"
    ]
  }
}
