{
  "name": "audio-recorder",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "TypeScript audio recorder library scaffold with Vite, Vitest, and Playwright.",
  "scripts": {
    "dev": "vite",
    "dev:playground": "npm run build && vite --open /playground/",
    "build": "vite build && tsc -p tsconfig.build.json",
    "preview": "vite preview",
    "prepare": "husky",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run test:unit && npm run test:functional",
    "test:unit": "vitest run --coverage",
    "test:functional": "playwright test",
    "test:functional:headed": "playwright test --headed",
    "lint": "eslint . --fix",
    "format": "prettier --write .",
    "commitlint": "commitlint --edit",
    "check": "npm run lint && npm run typecheck && npm run test && npm run build && npm run verify:exports",
    "verify:exports": "node ./scripts/verify-exports.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./plugins/level-meter": {
      "types": "./dist/plugins/level-meter/index.d.ts",
      "import": "./dist/plugins/level-meter/index.js"
    },
    "./storage/opfs": {
      "types": "./dist/storage/opfs/index.d.ts",
      "import": "./dist/storage/opfs/index.js"
    },
    "./storage/indexeddb": {
      "types": "./dist/storage/indexeddb/index.d.ts",
      "import": "./dist/storage/indexeddb/index.js"
    },
    "./plugins/streaming-export": {
      "types": "./dist/plugins/streaming-export/index.d.ts",
      "import": "./dist/plugins/streaming-export/index.js"
    },
    "./codecs/mp3": {
      "types": "./dist/codecs/mp3/index.d.ts",
      "import": "./dist/codecs/mp3/index.js"
    },
    "./codecs/base": {
      "types": "./dist/codecs/base/index.d.ts",
      "import": "./dist/codecs/base/index.js"
    },
    "./codecs/g711": {
      "types": "./dist/codecs/g711/index.d.ts",
      "import": "./dist/codecs/g711/index.js"
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lamejs": "^1.2.1",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.0.12",
    "vitest": "^4.1.8"
  },
  "prettier": {
    "singleQuote": false,
    "semi": false,
    "trailingComma": "es5",
    "bracketSpacing": true,
    "endOfLine": "crlf",
    "bracketSameLine": false,
    "cursorOffset": 2
  },
  "lint-staged": {
    "src/**/*.{ts,tsx,json,css,scss,md}": [
      "npm lint"
    ]
  }
}
